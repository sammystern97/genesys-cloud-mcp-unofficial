# Genesys Cloud OAuth 2.0 Client Credentials
# Create an OAuth client at: Admin > Integrations > OAuth > Add Client
# Grant type: Client Credentials
GENESYS_CLIENT_ID=your-client-id-here
GENESYS_CLIENT_SECRET=your-client-secret-here

# Your Genesys Cloud region
# Options: us-east-1 | us-west-2 | eu-west-1 | eu-central-1 | eu-west-2
#          ap-southeast-2 | ap-northeast-1 | ap-south-1 | ca-central-1 | us-gov-west-1
GENESYS_REGION=us-east-1
